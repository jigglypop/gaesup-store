{
  "name": "@gaesup-state/adapter",
  "version": "0.0.1",
  "description": "Framework-agnostic adapters for Gaesup-State",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/gaesup/gaesup-state#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaesup/gaesup-state.git",
    "directory": "packages/adapter"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "default": "./dist/index.esm.js"
    },
    "./reactive": {
      "types": "./dist/reactive.d.ts",
      "import": "./dist/reactive.esm.js",
      "require": "./dist/reactive.js"
    },
    "./signals": {
      "types": "./dist/signals.d.ts",
      "import": "./dist/signals.esm.js",
      "require": "./dist/signals.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "pack:dry": "pnpm run build && npm pack --dry-run"
  },
  "dependencies": {
    "gaesup-state": "0.0.1"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "framework-agnostic",
    "adapter",
    "wasm",
    "webassembly",
    "reactive",
    "signals",
    "state-management"
  ]
} 
