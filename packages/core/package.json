{
  "name": "gaesup-state",
  "version": "0.0.1",
  "description": "TypeScript API for Gaesup-State, a Rust/WASM state runtime with auto stores, resources, pipelines, and container compatibility checks",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/gaesup/gaesup-state#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaesup/gaesup-state.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/gaesup/gaesup-state/issues"
  },
  "keywords": [
    "state-management",
    "wasm",
    "webassembly",
    "rust",
    "react-query",
    "zustand",
    "jotai",
    "webgpu",
    "container-runtime"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./immer": {
      "types": "./dist/immer.d.ts",
      "import": "./dist/immer.js",
      "default": "./dist/immer.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js",
      "default": "./dist/middleware.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "pack:dry": "pnpm run build && npm pack --dry-run"
  },
  "dependencies": {
    "gaesup-state-core-rust": "0.0.1"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
} 
