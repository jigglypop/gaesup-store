{
  "name": "@gaesup-state/registry",
  "version": "0.0.1",
  "description": "Registry server for Gaesup-State WASM containers",
  "type": "module",
  "license": "MIT",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "gaesup-registry": "./bin/registry-server.js"
  },
  "files": [
    "dist",
    "bin",
    "public"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch & node dist/server.js",
    "start": "node dist/server.js",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/helmet": "^11.1.0",
    "@fastify/rate-limit": "^8.0.0",
    "gaesup-state": "0.0.1",
    "better-sqlite3": "^9.1.0",
    "fastify": "^4.24.0",
    "fastify-cors": "^6.1.0",
    "fastify-multipart": "^7.6.0",
    "fastify-static": "^4.7.0",
    "minio": "^7.1.0",
    "pino": "^8.17.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaesup/gaesup-state.git",
    "directory": "packages/registry"
  },
  "keywords": [
    "wasm",
    "container",
    "registry",
    "server",
    "api"
  ]
} 
