{
  "name": "@gaesup-state/react",
  "version": "0.0.1",
  "description": "React integration for Gaesup-State",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/gaesup/gaesup-state#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaesup/gaesup-state.git",
    "directory": "packages/frameworks/react"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "pack:dry": "pnpm run build && npm pack --dry-run"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "dependencies": {
    "gaesup-state": "workspace:^"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "hooks",
    "wasm",
    "webassembly",
    "state-management"
  ]
} 
