{
  "name": "@gaesup-state/vue",
  "version": "0.0.1",
  "description": "Vue integration for Gaesup-State",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/gaesup/gaesup-state#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaesup/gaesup-state.git",
    "directory": "packages/frameworks/vue"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "default": "./dist/index.esm.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "pack:dry": "pnpm run build && npm pack --dry-run"
  },
  "dependencies": {
    "gaesup-state": "workspace:^",
    "@gaesup-state/adapter": "workspace:^"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@vue/composition-api": "^1.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "vue": "^3.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "vue",
    "composition-api",
    "wasm",
    "webassembly",
    "state-management"
  ]
} 
